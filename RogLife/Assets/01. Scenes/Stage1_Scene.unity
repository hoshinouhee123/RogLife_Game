--- !u!114 &340273860
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 340273858}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\n\n\nLogLife\n\n\uC5D4\uB529\uD06C\uB808\uB527\uC784\n(\uC788\uC5B4\uBCF4\uC774\uB294
    \uD14D\uC2A4\uD2B8)\n\n[\uB0B4\uAC00 \uAC00\uC9C0\uACE0 \uC788\uB294 \uC2A4\uD300
    \uAC8C\uC784 \uBAA9\uB85D]\n- \uCCA0\uAD8C8\n- \uD398\uB974\uC18C\uB098 5 \uB85C\uC584\n-
    \uD398\uB974\uC18C\uB098 3 \uB9AC\uB85C\uB4DC\n- \uD398\uB974\uC18C\uB098 3 \uD3EC\uD130\uBE14\n-
    \uD398\uB974\uC18C\uB098 4 \uB514 \uC5BC\uD2F0\uB9E5\uC2A4 \uC6B8\uD2B8\uB77C
    \uC218\uD50C\uB809\uC2A4\n- \uC774\uD130\uB110 \uB9AC\uD134\n- \uB514\uC81C\uC774
    \uB9E5\uC2A4\n- \uB2E4\uD0A4\uC2A4\uD2B8 \uB358\uC804\n- \uC2AC\uB808\uC774 \uB354
    \uC2A4\uD30C\uC774\uC5B4\n- \uB9BC\uC6D4\uB4DC\n- \uD30C\uD2F0 \uC560\uB2C8\uBA40\uC988\n-
    \uB77C\uBE44\uB9AC\uBE44\n- Left 4 Dead 2\n- \uD06C\uB85C\uB178 \uC544\uD06C\n-
    \uBC85\uC0F7 \uB8F0\uB81B\n- \uC2DD\uC2A4\uD0C0 \uAC8C\uC774\uD2B8:\uC2A4\uD0C0\uD2B8\uB808\uC77C\n-
    \uC18C\uB2C9 \uB808\uC774\uC2F1 \uD06C\uB85C\uC2A4 \uC6D4\uB4DC\n- \uC5BC\uBD88\uCDA4\n-
    \uB3D9\uBC29\uC57C\uC791\uC2DD\uB2F9\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 537d72bbdd958da4cb69c86400c2407f, type: 2}
